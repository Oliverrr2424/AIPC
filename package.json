{
  "name": "ai-pc-builder",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:next": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:rag": "node scripts/rag-regression.mjs",
    "test:conversation": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/conversation-regression.ts",
    "db:generate": "prisma generate",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} prisma migrate deploy",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} prisma db push",
    "db:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/seed.ts",
    "db:import-sqlite": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/migrate-sqlite-data.ts",
    "rag:index": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/index-knowledge.ts",
    "rag:eval": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/rag-retrieval-eval.ts",
    "sync:prices": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/sync-prices.ts",
    "sync:benchmarks": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/sync-benchmarks.ts",
    "crawl:parts": "node scripts/crawl-parts.mjs --target 50",
    "crawl:ca": "node scripts/ca-crawl/crawl.mjs",
    "crawl:ca:normalize": "node scripts/ca-crawl/normalize.mjs",
    "import:ca": "DATABASE_URL=${DATABASE_URL:-postgresql://aipc:aipc@localhost:5432/aipc?schema=public} tsx scripts/import-ca-prices.ts",
    "audit:parts": "tsx scripts/audit-parts-data.ts",
    "sync:all": "npm run db:seed && npm run rag:index && npm run sync:prices && npm run sync:benchmarks"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/react": "^2.1.7",
    "@prisma/client": "^6.19.3",
    "next": "^15.2.4",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.180.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
