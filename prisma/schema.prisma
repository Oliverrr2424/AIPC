// AIPC database schema — PostgreSQL + pgvector.
// Local development uses the pgvector Docker image; production can use any
// PostgreSQL provider that supports the vector extension.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Canonical hardware part. `specsJson` keeps category-specific fields
/// (socket, vramGb, formFactor, ...) without one column per attribute.
model Part {
  id           String   @id
  category     String
  name         String
  brand        String
  chipset      String?
  imageUrl     String?
  productUrl   String?
  specSourceUrl String?
  priceSourceUrl String?
  priceKind    String?
  priceAsOf    DateTime?
  tags         String[]
  summary      String
  specsJson    Json
  listPriceUsd Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([brand])

  priceSnapshots  PriceSnapshot[]
  benchmarkResults BenchmarkResult[]
  knowledgeChunks KnowledgeChunk[]
}

/// A citable knowledge unit used by semantic retrieval. The vector column is
/// queried through parameterized raw SQL because Prisma represents pgvector as
/// an Unsupported field.
model KnowledgeChunk {
  id             String   @id
  title          String
  content        String
  tags           String[]
  category       String?
  partId         String?
  sourceUrl      String?
  sourceTitle    String?
  contentHash    String
  embeddingModel String?
  embedding      Unsupported("vector(384)")?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  part Part? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([partId])
  @@index([contentHash])
}

/// One row per (part, retailer, timestamp). Append-only — never mutated.
/// This is what powers the historical price curve.
model PriceSnapshot {
  id          String   @id @default(cuid())
  partId      String
  retailer    String   // "bestbuy" | "pcpartpicker" | "newegg" | "list"
  region      String   @default("US") // ISO-3166-1 alpha-2
  priceUsd    Float
  currency    String   @default("USD")
  inStock     Boolean  @default(true)
  url         String?
  capturedAt  DateTime @default(now())

  part        Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId, capturedAt])
  @@index([retailer, capturedAt])
  @@index([partId, retailer, capturedAt])
}

/// A single benchmark measurement for one part.
/// One part can have many rows across benchmarks/games/resolutions.
model BenchmarkResult {
  id            String   @id @default(cuid())
  partId        String
  // e.g. "cyberpunk-2077", "blender-classroom", "llama-70b-q4"
  benchmarkKey  String
  benchmarkKind String   // "fps" | "render-seconds" | "tokens-per-second" | "score"
  workload      String   // e.g. "gaming", "ai-inference", "rendering"
  resolution    String?  // "1080p" | "1440p" | "4k" | null
  quality       String?  // "ultra" | "high" | "medium" ...
  value         Float    // the headline number (fps / seconds / tok/s)
  unit          String   // "fps" | "s" | "tok/s" | "pts"
  sourceName    String   // e.g. "TechPowerUp", "OpenLLM", "Blender Open Data"
  sourceUrl     String?
  publishedAt   DateTime?
  capturedAt    DateTime @default(now())

  part          Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId, benchmarkKey])
  @@index([benchmarkKind, workload])
  @@index([benchmarkKey, resolution, quality])
}

/// Sync run log — useful for cron monitoring and debugging stale data.
model SyncRun {
  id          String   @id @default(cuid())
  source      String   // "bestbuy" | "benchmarks-techpowerup" | ...
  status      String   // "ok" | "partial" | "failed"
  partsTouched Int     @default(0)
  error       String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
}
