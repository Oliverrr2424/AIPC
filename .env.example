# Copy to .env.local and fill in.
# AI providers (optional — app degrades gracefully without them)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_API_KEY=
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=gemini-embedding-2
LOCAL_EMBEDDING_MODEL=Xenova/multilingual-e5-small
HF_ENDPOINT=https://hf-mirror.com
EMBEDDING_DIMENSIONS=384

# Remote Ollama embedding server (optional — set EMBEDDING_PROVIDER=ollama to use).
# Point at a GPU box on your Tailscale net, e.g. an RTX 5090 running nomic-embed-text.
OLLAMA_EMBEDDING_URL=http://100.103.114.92:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# PostgreSQL + pgvector. This matches docker-compose.yml for local development.
DATABASE_URL="postgresql://aipc:aipc@localhost:5432/aipc?schema=public"

# North American price providers
# BestBuy official API — https://developer.bestbuy.com
BESTBUY_API_KEY=

# PCPartParser fallback (no key required, public pages)
PCPARTPARSER_BASE_URL="https://pcpartpicker.com"
# Off by default. Enable only after confirming your intended use complies with
# the source site's current terms and robots policy.
ENABLE_PCPARTPICKER_SCRAPE=false

# Sync API bearer token — protects /api/sync from public triggers
SYNC_API_TOKEN=

# Vercel Cron bearer secret — Vercel injects it into scheduled GET requests
CRON_SECRET=

# Default region for price lookups (NA = US + CA)
PRICE_REGION="US"
